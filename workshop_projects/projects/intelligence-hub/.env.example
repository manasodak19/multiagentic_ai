# Multi-Agent Workshop - API Keys
# Copy this file to .env and fill in your key:
#   cp .env.example .env

# Groq API (recommended - free tier available, very fast inference)
# Get a free key at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-key-here

# Embeddings use a local open-source model (sentence-transformers)
# No API key needed - runs completely free on your machine